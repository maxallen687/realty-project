# Supabase — copie estes valores do seu projeto em Settings > API
# (NÃO comite o arquivo .env real; ele já está no .gitignore)
#
# Em produção, configure estes dois valores na Vercel:
#   Settings > Environment Variables
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public-aqui
